# Copia para `.env.local` (não é commitado) e preenche os valores.

# Royal Banking — Cash In (Pix). A chave NUNCA vai para o browser.
ROYALBANKING_API_KEY=

# URL pública HTTPS que a Royal Banking pode chamar (webhook), ex.:
# https://seudominio.com/api/webhooks/royalbanking/pix
ROYALBANKING_PIX_CALLBACK_URL=

# Base pública do site (uma delas basta). SITE_URL/APP_URL são só servidor e valem no próximo deploy.
# NEXT_PUBLIC_APP_URL exige novo build depois de definida na Vercel.
SITE_URL=
APP_URL=
NEXT_PUBLIC_APP_URL=
