# Copia para `.env.local` (não é commitado) e preenche os valores.

# Painel /admin — senha de acesso e segredo para assinar o cookie de sessão (servidor apenas).
# ADMIN_SESSION_SECRET: mínimo 16 caracteres; use um valor aleatório longo (não reutilize a senha literal como segredo em produção).
ADMIN_PASSWORD=
ADMIN_SESSION_SECRET=

# Royal Banking — Cash In (Pix). A chave NUNCA vai para o browser.
ROYALBANKING_API_KEY=

# URL pública HTTPS que a Royal Banking pode chamar (webhook), ex.:
# https://seudominio.com/api/webhooks/royalbanking/pix
# Em local, use um túnel (ngrok) — localhost não recebe POST da gateway.
ROYALBANKING_PIX_CALLBACK_URL=

# Origem pública do site (sem barra final). Na Vercel define também para montar o webhook do Pix.
# Ex.: https://camisa-brasil-landing.vercel.app
SITE_URL=

# Base pública do site (uma delas basta). SITE_URL/APP_URL são só servidor e valem no próximo deploy.
# NEXT_PUBLIC_APP_URL exige novo build depois de definida na Vercel.
SITE_URL=
APP_URL=
NEXT_PUBLIC_APP_URL=

# Supabase — URL e chave anónima (browser / servidor). Ver Project Settings → API.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Só servidor — necessária para gravar pedidos “cartão pendente” no checkout e outras escritas com RLS fechado.
# Nunca uses NEXT_PUBLIC_* com esta chave.
SUPABASE_SERVICE_ROLE_KEY=
